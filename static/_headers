/
    X-Frame-Options: SAMEORIGIN
    X-Content-Type-Options: nosniff
    Referrer-Policy: strict-origin-when-cross-origin
    Permissions-Policy: accelerometer=(), camera=(), geolocation=(), microphone=(), payment=(), usb=()
    Content-Security-Policy: default-src 'self'; base-uri 'self'; connect-src 'self' https://eu.i.posthog.com; font-src 'self'; form-action 'self'; frame-ancestors 'none'; frame-src https://challenges.cloudflare.com; img-src 'self' data: https:; object-src 'none'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline';
/*.js
    Cache-Control: public, max-age=31536000, immutable
/fonts/*
    Cache-Control: public, max-age=31536000, immutable
/og/*
    Cache-Control: public, max-age=31536000, immutable
/_astro/*
    Cache-Control: public, max-age=31536000
    Access-Control-Allow-Origin: *
