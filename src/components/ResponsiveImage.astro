---
import {
  buildResponsiveContentfulImage,
  resolveContentfulAltText,
  type ImageFormat,
  type ImageTransform,
  type ContentfulImage,
} from '../lib/contentful-images'

type Props = {
  alt?: string
  asset?: ContentfulImage
  class?: string
  fallbackAlt?: string
  fallbackFormat?: ImageFormat
  fetchpriority?: 'auto' | 'high' | 'low'
  formats?: ImageFormat[]
  loading?: 'eager' | 'lazy'
  priority?: boolean
  sizes?: string
  transform?: ImageTransform
  widths?: number[]
}

const {
  alt,
  asset,
  class: className,
  fallbackAlt,
  fallbackFormat = 'jpg',
  fetchpriority = 'auto',
  formats = ['avif', 'webp'],
  loading = 'lazy',
  priority = false,
  sizes = '100vw',
  transform = { q: 80 },
  widths = [],
} = Astro.props as Props

const image = buildResponsiveContentfulImage(asset, {
  fallbackFormat,
  formats,
  transform,
  widths,
})
const imageAlt = resolveContentfulAltText(asset, alt, fallbackAlt)
const imageLoading = priority ? 'eager' : loading
const imageFetchPriority = priority ? 'high' : fetchpriority
---

{
  asset && image.fallbackSrc ? (
    <picture>
      {image.sources.map((source) => (
        <source sizes={sizes} srcset={source.srcSet} type={source.type} />
      ))}
      <img
        alt={imageAlt}
        class={className}
        decoding="async"
        fetchpriority={imageFetchPriority}
        height={image.fallbackHeight}
        loading={imageLoading}
        sizes={image.fallbackSrcSet ? sizes : undefined}
        src={image.fallbackSrc}
        srcset={image.fallbackSrcSet}
        width={image.fallbackWidth}
      />
    </picture>
  ) : null
}
