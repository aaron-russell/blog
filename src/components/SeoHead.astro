---
import { siteMetadata } from '../lib/site-config'
import { buildPageTitle, buildSeoMetaTags, buildWebsiteJsonLd } from '../utils/seo-data'

type Props = {
  alt?: string
  canonical?: string
  description?: string
  documentTitle?: string
  image?: string
  imageHeight?: number
  imageType?: string
  imageWidth?: number
  modifiedTime?: string
  publishedTime?: string
  robots?: string
  structuredData?: Array<Record<string, unknown>>
  title?: string
  turnstile?: boolean
  type?: string
}

const {
  alt,
  canonical,
  description = '',
  documentTitle,
  image,
  imageHeight,
  imageType,
  imageWidth,
  modifiedTime,
  publishedTime,
  robots,
  structuredData = [],
  title,
  turnstile = false,
  type = 'website',
} = Astro.props as Props

const pageTitle = documentTitle || buildPageTitle(title, siteMetadata.title)
const metaTags = buildSeoMetaTags({
  canonical,
  description,
  image,
  imageAlt: alt,
  imageHeight,
  imageType,
  imageWidth,
  modifiedTime,
  publishedTime,
  siteMetadata,
  title: documentTitle || title,
  type,
})
const websiteLdJson = buildWebsiteJsonLd(siteMetadata)
---

<title>{pageTitle}</title>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
{robots ? <meta name="robots" content={robots} /> : null}
{canonical ? <link rel="canonical" href={canonical} /> : null}
<link rel="alternate" type="application/rss+xml" title={`${siteMetadata.title} RSS`} href="/rss.xml" />
<link
  rel="preload"
  href="/fonts/Inter-roman.var.woff2?v=3.19"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5" />
<meta name="theme-color" content="#f4edf8" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#222222" media="(prefers-color-scheme: dark)" />
{metaTags.map((entry) => <meta {...entry} />)}
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLdJson)} />
{structuredData.map((entry) => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
))}
{
  turnstile ? (
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    ></script>
  ) : null
}
