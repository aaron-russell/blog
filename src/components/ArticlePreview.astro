---
import Container from './Container.astro'
import ResponsiveImage from './ResponsiveImage.astro'
import Tags from './Tags.astro'
import styles from './article-preview.module.css'
import { createExcerpt } from '../lib/blog'
import { isWithinLastSixMonths } from '../lib/date'

const { linkTagsToFilter = true, posts = [] } = Astro.props
const getBadge = (post: any) => {
  if (post.editorialStatus === 'archived') return 'Archive'
  if (post.editorialStatus === 'historical') return 'Historical'
  if (post.editorialStatus === 'needs-review') return 'Needs review'
  if (post.displayDateLabel === 'Updated' && post.rawDisplayDate) {
    return `Reviewed ${new Date(post.rawDisplayDate).getUTCFullYear()}`
  }
  return isWithinLastSixMonths(post.rawDate) ? 'Fresh note' : undefined
}
---

{
  Array.isArray(posts) && posts.length > 0 ? (
    <Container>
      <ul class={styles['article-list']}>
        {posts.map((post: any) => (
          <li class={`${styles.card} surface`}>
            <article class={styles.article}>
              {
                getBadge(post) ? (
                  <span class={styles.badge}>{getBadge(post)}</span>
                ) : null
              }
              <ResponsiveImage
                asset={post.heroImage}
                alt=""
                class={styles.image}
                fallbackAlt=""
                loading="lazy"
                sizes="(min-width: 1140px) 424px, (min-width: 720px) 45vw, 100vw"
                transform={{ fit: 'fill', h: 240, q: 72, w: 424 }}
                widths={[320, 424, 640, 848]}
              />
              <div class={styles.heading}>
                <p class={styles.kicker}>{post.contentGroup || 'Latest writing'}</p>
                <span class={styles.readMore}>Read article</span>
              </div>
              <h2 class={styles.title}>
                <a href={`/blog/${post.slug}/`} class={styles.link}>{post.title}</a>
              </h2>
              <p class={styles.excerpt}>
                {createExcerpt(post.descriptionPlainText || post.bodyPlainText || '', 156)}
              </p>
              <div class={styles.meta}>
                <small>{post.publishDate}</small>
                <Tags linkToFilter={linkTagsToFilter} tags={post.tags} />
              </div>
            </article>
          </li>
        ))}
      </ul>
    </Container>
  ) : null
}
