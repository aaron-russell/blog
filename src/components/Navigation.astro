---
import styles from './navigation.module.css'
import ThemeSwitcher from './ThemeSwitcher.astro'

const pathname = Astro.url.pathname

const isActive = (href: string) => {
  if (href === '/') {
    return pathname === '/'
  }

  return pathname === href || pathname.startsWith(href)
}
---

<a class={styles.skipLink} href="#main-content">Skip to content</a>
<nav role="navigation" class={styles.container} aria-label="Main">
  <div class={styles.inner}>
    <a href="/" class={styles.logoLink} aria-label="Aaron Russell home">
      <span class={styles.brand}>
        <span class={styles.brandName}>Aaron Russell</span>
        <span class={styles.brandMeta}>Engineering notebook</span>
      </span>
    </a>
    <div class={styles.controls}>
      <ul class={styles.navigation}>
        <li class={styles.navigationItem}>
          <a href="/" class:list={{ active: isActive('/') }}>Home</a>
        </li>
        <li class={styles.navigationItem}>
          <a href="/blog/" class:list={{ active: isActive('/blog/') }}>Blog</a>
        </li>
        <li class={styles.navigationItem}>
          <a href="/about/" class:list={{ active: isActive('/about/') }}>About</a>
        </li>
        <li class={styles.navigationItem}>
          <a href="/contact/" class:list={{ active: isActive('/contact/') }}>Contact</a>
        </li>
      </ul>
      <a href="/blog/" class={styles.ctaLink}>
        Latest notes
      </a>
      <ThemeSwitcher />
    </div>
  </div>
</nav>
