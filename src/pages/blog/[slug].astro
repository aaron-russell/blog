---
import readingTime from 'reading-time'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero from '../../components/Hero.astro'
import ArticlePreview from '../../components/ArticlePreview.astro'
import Tags from '../../components/Tags.astro'
import { getAllBlogPosts, getAuthor } from '../../lib/contentful'
import {
  annotateArticleHtml,
  buildArticleFaqs,
  buildArticleSummaryPoints,
  getRelatedPosts,
} from '../../lib/blog'
import { findPostByTerms } from '../../lib/content-links'
import { projects } from '../../lib/site-config'
import {
  buildContentfulSocialImageUrl,
  CONTENTFUL_SOCIAL_IMAGE_TYPE,
} from '../../lib/contentful-images'
import { OG_IMAGE_HEIGHT, OG_IMAGE_WIDTH } from '../../lib/og'
import { resolveCanonicalUrl } from '../../utils/seo-data'
import {
  absoluteUrl,
  buildBlogPostingJsonLd,
  buildBreadcrumbListJsonLd,
  buildFAQPageJsonLd,
  buildSpeakableSpecification,
} from '../../utils/structured-data'
import styles from '../../templates/blog-post.module.css'

export async function getStaticPaths() {
  const [author, posts] = await Promise.all([getAuthor(), getAllBlogPosts()])

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      author,
      next: index === posts.length - 1 ? null : posts[index + 1],
      posts,
      post,
      previous: index === 0 ? null : posts[index - 1],
    },
  }))
}

const { author, next, post, posts, previous } = Astro.props
const timeToRead = readingTime(post.bodyPlainText || '').minutes
const { headings, html: articleHtml } = annotateArticleHtml(post.bodyHtml || '')
const relatedPosts = getRelatedPosts(post, posts, 3)
const canonicalUrl = resolveCanonicalUrl({
  canonical: post.canonical,
  pathname: `/blog/${post.slug}/`,
  siteUrl: author.website,
})
const seoImage = absoluteUrl(author.website, buildContentfulSocialImageUrl(post.heroImage?.url))
const speakable = buildSpeakableSpecification(['h1', '[data-article-body] > p:first-of-type'])
const blogPostingJsonLd = buildBlogPostingJsonLd(post, canonicalUrl, seoImage, { speakable })
const breadcrumbJsonLd = buildBreadcrumbListJsonLd(
  [
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog/' },
    { name: post.title, path: `/blog/${post.slug}/` },
  ],
  author.website
)
const relatedProject = projects.find((project) => findPostByTerms([post], project.relatedPostTerms))
const summaryPoints = buildArticleSummaryPoints({ headings, post, relatedProject, timeToRead })
const faqJsonLd = buildFAQPageJsonLd(
  buildArticleFaqs({ headings, post, relatedProject, timeToRead })
)
---

<BaseLayout
  seo={{
    alt: `${post.title} social card`,
    canonical: canonicalUrl,
    description: post.descriptionPlainText,
    image: seoImage,
    imageHeight: OG_IMAGE_HEIGHT,
    imageType: CONTENTFUL_SOCIAL_IMAGE_TYPE,
    imageWidth: OG_IMAGE_WIDTH,
    modifiedTime: post.rawUpdatedDate || post.rawDate,
    publishedTime: post.rawDate,
    structuredData: [blogPostingJsonLd, breadcrumbJsonLd, faqJsonLd],
    title: post.title,
    type: 'article',
  }}
>
  <div class={styles.progress} aria-hidden="true">
    <div class={styles.progressBar} data-reading-progress></div>
  </div>
  <Hero
    eyebrow={post.category || 'Article'}
    image={post.heroImage}
    imageAlt={post.heroImage?.description || post.title}
    title={post.title}
    contentHtml={post.descriptionHtml}
  />
  <div class={styles.container}>
    <nav aria-label="Breadcrumb" class={styles.breadcrumbs}>
      <ol class={styles.breadcrumbList}>
        <li><a href="/">Home</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li aria-current="page">{post.title}</li>
      </ol>
    </nav>
    <div class={`${styles.metaPanel} surface`}>
      <div class={styles.metaGroup}>
        <span class={styles.metaLabel}>Written by</span>
        <span>{post.author?.name}</span>
      </div>
      <div class={styles.metaGroup}>
        <span class={styles.metaLabel}>Published</span>
        <time datetime={post.rawDate}>{post.publishDate}</time>
      </div>
      {
        post.updatedDate ? (
          <div class={styles.metaGroup}>
            <span class={styles.metaLabel}>Updated</span>
            <time datetime={post.rawUpdatedDate}>{post.updatedDate}</time>
          </div>
        ) : null
      }
      <div class={styles.metaGroup}>
        <span class={styles.metaLabel}>Reading time</span>
        <span>{timeToRead.toFixed(0)} minute read</span>
      </div>
      <div class={styles.metaTags}>
        <Tags linkToFilter tags={post.tags} />
      </div>
    </div>
    {relatedProject ? (
      <aside class={`${styles.projectLink} surface`}>
        <div><span class={styles.metaLabel}>Related project</span><strong>{relatedProject.name}</strong></div>
        <p>{relatedProject.description}</p>
        <a href={relatedProject.href}>Explore the project →</a>
      </aside>
    ) : null}
    <section class={`${styles.metaPanel} surface`} aria-labelledby="key-findings">
      <div class={styles.metaGroup}>
        <h2 id="key-findings" class={styles.metaLabel}>Key findings</h2>
      </div>
      <ul>
        {summaryPoints.map((point) => <li>{point}</li>)}
      </ul>
    </section>
    <div class={styles.article}>
      {
        headings.length >= 3 ? (
          <aside class={`${styles.toc} surface`}>
            <p class={styles.tocTitle}>On this page</p>
            <ol>
              {headings.map((heading) => (
                <li>
                  <a
                    class:list={{ [styles.tocSubItem]: heading.depth > 2 }}
                    data-toc-link
                    href={`#${heading.id}`}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </aside>
        ) : null
      }
      <div class={styles.body} data-article-body set:html={articleHtml} />
      <aside class={`${styles.articleCta} surface`}>
        <span class="eyebrow">From the workbench</span>
        <h2>Want the next useful note?</h2>
        <p>Browse the project context, keep reading by topic, or send me a specific question about the implementation.</p>
        <div><a href="/projects/">Explore projects →</a><a href="/blog/">Browse all writing →</a><a href="/contact/">Ask a question →</a></div>
      </aside>
      {
        previous || next ? (
          <nav aria-label="Post navigation" class={styles.postNav}>
            <ul class={styles.articleNavigation}>
              {previous ? (
                <li>
                  <a class={`${styles.navCard} surface`} href={`/blog/${previous.slug}/`} rel="prev">
                    <span class={styles.navLabel}>Previous article</span>
                    <strong>← {previous.title}</strong>
                  </a>
                </li>
              ) : null}
              {next ? (
                <li class:list={{ [styles.nextOnly]: !previous }}>
                  <a class={`${styles.navCard} surface`} href={`/blog/${next.slug}/`} rel="next">
                    <span class={styles.navLabel}>Next article</span>
                    <strong>{next.title} →</strong>
                  </a>
                </li>
              ) : null}
            </ul>
          </nav>
        ) : null
      }
    </div>
  </div>
  {
    relatedPosts.length > 0 ? (
      <section class={styles.relatedSection}>
        <div class={styles.relatedHeader}>
          <span class="eyebrow">Related posts</span>
          <h2>Keep reading</h2>
        </div>
        <ArticlePreview posts={relatedPosts} />
      </section>
    ) : null
  }
  <script is:inline>
    const progressBar = document.querySelector('[data-reading-progress]')
    const articleBody = document.querySelector('[data-article-body]')
    const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'))

    const updateProgress = () => {
      if (!(articleBody instanceof HTMLElement) || !(progressBar instanceof HTMLElement)) {
        return
      }

      const rect = articleBody.getBoundingClientRect()
      const viewHeight = window.innerHeight
      const total = Math.max(rect.height - viewHeight * 0.35, 1)
      const travelled = Math.min(Math.max(-rect.top + viewHeight * 0.15, 0), total)
      progressBar.style.transform = `scaleX(${travelled / total})`
    }

    const observer = 'IntersectionObserver' in window
      ? new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const id = entry.target.getAttribute('id')
              if (!id) {
                return
              }

              const link = tocLinks.find((item) => item.getAttribute('href') === `#${id}`)
              if (link) {
                link.setAttribute('aria-current', entry.isIntersecting ? 'true' : 'false')
              }
            })
          },
          {
            rootMargin: '-20% 0px -65% 0px',
            threshold: [0, 1],
          }
        )
      : null

    document.querySelectorAll('pre').forEach((block) => {
      const code = block.querySelector('code')
      const button = document.createElement('button')
      button.className = 'copy-code-button'
      button.type = 'button'
      button.textContent = 'Copy'
      button.addEventListener('click', async () => {
        const text = code?.textContent || block.textContent || ''
        try {
          await navigator.clipboard.writeText(text)
          button.textContent = 'Copied'
          window.setTimeout(() => {
            button.textContent = 'Copy'
          }, 1600)
        } catch {
          button.textContent = 'Unable to copy'
        }
      })
      block.appendChild(button)
    })

    document.querySelectorAll('[data-article-body] h2, [data-article-body] h3').forEach((heading) => {
      observer?.observe(heading)
    })

    updateProgress()
    document.addEventListener('scroll', updateProgress, { passive: true })
    window.addEventListener('resize', updateProgress)
  </script>
</BaseLayout>
