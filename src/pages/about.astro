---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import Container from '../components/Container.astro'
import { getAllBlogPosts, getAuthor } from '../lib/contentful'
import { findPostByTerms } from '../lib/content-links'
import { projects, startHere } from '../lib/site-config'
import { buildContentfulImageUrl, buildContentfulSocialImageUrl } from '../lib/contentful-images'
import { CONTENTFUL_SOCIAL_IMAGE_TYPE } from '../lib/contentful-images'
import { OG_IMAGE_HEIGHT, OG_IMAGE_WIDTH } from '../lib/og'
import { absoluteUrl, buildPersonJsonLd, buildProfilePageJsonLd } from '../utils/structured-data'
import styles from './about.module.css'

const [author, posts] = await Promise.all([getAuthor(), getAllBlogPosts()])
const seoImage = buildContentfulSocialImageUrl(author.heroImage?.url)
const profileImage = author.profilePhoto?.url
  ? absoluteUrl(
      author.website,
      buildContentfulImageUrl(author.profilePhoto.url, { fm: 'jpg', q: 80, w: 1180 })
    )
  : undefined
const personJsonLd = buildPersonJsonLd(author, profileImage)
const profilePageJsonLd = buildProfilePageJsonLd(author, profileImage)
const locations = author.currentLocations?.filter(Boolean) || []
const employers = author.worksFor?.filter((item) => item?.companyName) || []
const affiliations = author.affiliatedWith?.filter((item) => item?.companyName) || []
const alumni = author.alumniOf?.filter((item) => item?.companyName) || []
const socialProfiles = [
  { label: 'GitHub', url: author.github },
  { label: 'LinkedIn', url: author.linkedIn },
  { label: 'Twitter / X', url: author.twitter },
].filter((item) => item.url)
const selectedWriting = startHere
  .map((item) => findPostByTerms(posts, item.terms))
  .filter((post, index, items): post is NonNullable<typeof post> =>
    Boolean(post && items.findIndex((item) => item?.slug === post.slug) === index)
  )
  .slice(0, 3)
const locationLabel = locations.length > 0
  ? locations.map((location) => [location.city, location.region, location.country].filter(Boolean).join(', ')).join(' · ')
  : 'Leeds, UK'
---

<BaseLayout
  seo={{
    alt: 'Aaron Russell about page social card',
    canonical: `${author.website}/about/`,
    description: author.description?.description || 'Background, current work, and links for Aaron Russell.',
    documentTitle: 'About Aaron Russell – Developer in Leeds, UK',
    image: seoImage,
    imageHeight: OG_IMAGE_HEIGHT,
    imageType: CONTENTFUL_SOCIAL_IMAGE_TYPE,
    imageWidth: OG_IMAGE_WIDTH,
    structuredData: [personJsonLd, profilePageJsonLd],
  }}
>
  <Hero
    eyebrow="About"
    image={author.profilePhoto || author.heroImage}
    imageAlt={author.profilePhoto?.description || author.heroImage?.description || `${author.name} portrait`}
    title={author.name}
    contentHtml="<p>UK-based software developer, product builder, and practical engineering writer.</p>"
  />

  <Container>
    <section class={styles.grid}>
      <article class={`${styles.panel} surface`}>
        <span class="eyebrow">The short version</span>
        <h2>I build software that has to work outside the demo.</h2>
        <p>{author.description?.description || 'I work across product engineering, delivery, and the web platform — from Angular and Firebase applications to static-first Astro and Cloudflare sites.'}</p>
        <p>I’m most interested in the point where sound engineering meets useful product delivery: making the right trade-offs, shipping the work, and learning from what happens next.</p>
        {author.jobTitle ? <p><strong>Role:</strong> {author.jobTitle}</p> : null}
        <p><strong>Based in:</strong> {locationLabel}</p>
      </article>

      <article class={`${styles.panel} surface`}>
        <span class="eyebrow">Elsewhere</span>
        <h2>Profiles and contact</h2>
        <ul class={styles.linkList}>
          <li><a href="/contact/">Contact me</a></li>
          {socialProfiles.map((profile) => <li><a href={profile.url} rel="me noopener noreferrer">{profile.label} ↗</a></li>)}
          <li><a href="/editorial-policy/">Editorial policy</a></li>
        </ul>
      </article>

      <article class={`${styles.panel} surface`}>
        <span class="eyebrow">Experience</span>
        <h2>Products, platforms, and delivery.</h2>
        <p>My background spans software engineering and product delivery, including work on public-sector digital services and independent products.</p>
        <div class={styles.techList} aria-label="Main technologies">
          {['Angular', 'React', 'Node.js', 'Firebase', 'Cloudflare', 'Astro', 'Contentful', 'TypeScript'].map((item) => <span>{item}</span>)}
        </div>
      </article>

      <article class={`${styles.panel} surface`}>
        <span class="eyebrow">Current interests</span>
        <h2>What I’m exploring</h2>
        <ul class={styles.linkList}>
          <li>AI-assisted development workflows that improve real delivery</li>
          <li>Indie product building and maintainable product systems</li>
          <li>Performance, accessibility, SEO, and the modern web platform</li>
          <li>Static-first architecture with useful edge capabilities</li>
        </ul>
        <a class={styles.textLink} href="/now/">See what I’m doing now →</a>
      </article>

      <article class={`${styles.panel} surface`}>
        <span class="eyebrow">This site</span>
        <h2>An engineering notebook with receipts.</h2>
        <p>I write about Astro, Cloudflare, Angular, Firebase, Contentful, AI-assisted delivery, performance, SEO, and the awkward middle between “it works” and “it is ready”.</p>
        <div class={styles.linkRow}><a href="/blog/">Browse the writing →</a><a href="/uses/">See the tools I use →</a></div>
      </article>

      {employers.length > 0 ? (
        <article class={`${styles.panel} surface`}>
          <h2>Current work</h2>
          <ul class={styles.linkList}>
            {employers.map((company) => (
              <li>
                {company.website ? (
                  <a href={company.website} rel="noopener noreferrer">{company.companyName}</a>
                ) : (
                  company.companyName
                )}
              </li>
            ))}
          </ul>
        </article>
      ) : null}

      {affiliations.length > 0 || alumni.length > 0 ? (
        <article class={`${styles.panel} surface`}>
          <h2>Background</h2>
          <ul class={styles.linkList}>
            {affiliations.map((company) => (
              <li>
                {company.website ? (
                  <a href={company.website} rel="noopener noreferrer">{company.companyName}</a>
                ) : (
                  company.companyName
                )}
              </li>
            ))}
            {alumni.map((company) => (
              <li>
                {company.website ? (
                  <a href={company.website} rel="noopener noreferrer">{company.companyName}</a>
                ) : (
                  company.companyName
                )}
              </li>
            ))}
          </ul>
        </article>
      ) : null}
    </section>

    <section class={styles.sectionBlock}>
      <div class={styles.sectionHeader}><span class="eyebrow">Selected projects</span><h2>Work I can point to.</h2></div>
      <div class={styles.grid}>
        {projects.map((project) => (
          <article class={`${styles.panel} surface`}><span class={styles.status}>{project.status}</span><h3><a href={project.href}>{project.name}</a></h3><p>{project.description}</p><a class={styles.textLink} href={project.href}>View project →</a></article>
        ))}
      </div>
    </section>

    {selectedWriting.length > 0 ? (
      <section class={styles.sectionBlock}>
        <div class={styles.sectionHeader}><span class="eyebrow">Selected writing</span><h2>A few useful places to start.</h2></div>
        <div class={styles.writingGrid}>
          {selectedWriting.map((post) => (
            <a class={`${styles.writingCard} surface`} href={`/blog/${post.slug}/`}><span>{post.category || 'Engineering note'}</span><h3>{post.title}</h3><p>{post.descriptionPlainText}</p></a>
          ))}
        </div>
      </section>
    ) : null}

    <section class={`${styles.contactPanel} surface`}>
      <div><span class="eyebrow">Say hello</span><h2>Have a specific problem worth discussing?</h2><p>Product engineering, app architecture, AI-assisted delivery, or something I wrote — useful context is always welcome.</p></div>
      <a href="/contact/">Contact me →</a>
    </section>
  </Container>
</BaseLayout>
