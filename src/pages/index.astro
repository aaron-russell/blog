---
import ArticlePreview from '../components/ArticlePreview.astro'
import Container from '../components/Container.astro'
import ProjectCard from '../components/ProjectCard.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { findPostByTerms } from '../lib/content-links'
import { getAuthor, getHomePagePosts } from '../lib/contentful'
import { buildContentfulImageUrl } from '../lib/contentful-images'
import {
  buildContentfulSocialImageUrl,
  CONTENTFUL_SOCIAL_IMAGE_TYPE,
} from '../lib/contentful-images'
import { OG_IMAGE_HEIGHT, OG_IMAGE_WIDTH } from '../lib/og'
import { homeConfig, projects, startHere } from '../lib/site-config'
import { getFeaturedTopics } from '../lib/topics'
import { absoluteUrl, buildPersonJsonLd } from '../utils/structured-data'
import styles from './index.module.css'

const [author, posts] = await Promise.all([getAuthor(), getHomePagePosts()])
const featuredTopics = getFeaturedTopics(posts).slice(0, 4)
const seoImage = buildContentfulSocialImageUrl(author.heroImage?.url)
const profileImage = author.profilePhoto?.url
  ? absoluteUrl(
      author.website,
      buildContentfulImageUrl(author.profilePhoto.url, { fm: 'jpg', q: 80, w: 1180 })
    )
  : undefined
const personJsonLd = buildPersonJsonLd(author, profileImage)
const startHereLinks = startHere.map((item) => {
  const post = findPostByTerms(posts, item.terms)
  return { ...item, href: post ? `/blog/${post.slug}/` : item.fallbackHref, post }
})
---

<BaseLayout
  seo={{
    alt: 'Aaron Russell home page social card',
    canonical: author.website,
    description: homeConfig.hero.intro,
    documentTitle: 'Aaron Russell – Software Engineering, AI Workflows & Static Web Notes',
    image: seoImage,
    imageHeight: OG_IMAGE_HEIGHT,
    imageType: CONTENTFUL_SOCIAL_IMAGE_TYPE,
    imageWidth: OG_IMAGE_WIDTH,
    structuredData: [personJsonLd],
  }}
>
  <section class={styles.heroSection}>
    <div class={styles.heroGrid}>
      <div class={`${styles.heroCard} surface`}>
        <span class="eyebrow">{homeConfig.hero.eyebrow}</span>
        <p class={styles.leadIn}>Practical software. Honest build notes. Useful experiments.</p>
        <h1 class={styles.statement}>{homeConfig.hero.title}</h1>
        <p class={styles.intro}>{homeConfig.hero.intro}</p>
        <div class={styles.signalRow}>
          <span class={styles.signalPill}>Indie products</span>
          <span class={styles.signalPill}>AI-assisted workflows</span>
          <span class={styles.signalPill}>Product engineering</span>
        </div>
        <div class={styles.actions}>
          <a class={styles.primaryAction} href="/projects/">
            Explore the projects
          </a>
          <a class={styles.secondaryAction} href="/blog/">
            Read the build notes
          </a>
        </div>
      </div>
      <div class={styles.statGrid}>
        <article class={`${styles.stat} surface`}>
          <span class={styles.statLabel}>Currently building</span>
          <p class={styles.statValue}>Pit Crew</p>
          <p class={styles.statText}>Fantasy motorsport leagues, podium predictions, and season-long bragging rights.</p>
        </article>
        <article class={`${styles.stat} surface`}>
          <span class={styles.statLabel}>Focus</span>
          <p class={styles.statValue}>Web x AI</p>
          <p class={styles.statText}>Angular and Firebase products; Astro, Contentful, and Cloudflare publishing.</p>
        </article>
        <article class={`${styles.stat} surface`}>
          <span class={styles.statLabel}>Based in</span>
          <p class={styles.statValue}>Leeds, UK</p>
          <p class={styles.statText}>Building products, delivering software, and sharing the useful parts in public.</p>
        </article>
      </div>
    </div>
  </section>

  <section class={styles.section}>
    <div class={styles.sectionHeader}>
      <div><span class="eyebrow">Start here</span><h2>A useful route into the work.</h2></div>
      <p>New here? Pick the thread closest to what you’re building. Every link resolves to a real article, project, or topic collection.</p>
    </div>
    <div class={styles.startGrid}>
      {startHereLinks.map((item, index) => (
        <a class={`${styles.startCard} surface`} href={item.href}>
          <span class={styles.startIndex}>0{index + 1}</span>
          <h3>{item.label}</h3>
          <p>{item.post?.descriptionPlainText || (item.label === 'Building Pit Crew' ? 'The product, architecture, and lessons behind a live fantasy motorsport app.' : 'A curated route through the most relevant notes and project work.')}</p>
          <span class={styles.featureLink}>{item.post ? 'Read article' : 'Explore topic'} →</span>
        </a>
      ))}
    </div>
  </section>

  <section class={styles.section}>
    <div class={styles.sectionHeader}>
      <div><span class="eyebrow">Selected projects</span><h2>Software with real users and real constraints.</h2></div>
      <p>Product stories, architecture decisions, and the parts I would approach differently the next time around.</p>
    </div>
    <div class={styles.projectGrid}>
      {projects.slice(0, 2).map((project) => <ProjectCard project={project} relatedPost={findPostByTerms(posts, project.relatedPostTerms)} />)}
    </div>
    <a class={styles.inlineCta} href="/projects/">See all projects →</a>
  </section>

  <section class={styles.section}>
    <div class={styles.sectionHeader}>
      <div>
        <span class="eyebrow">Current workbench</span>
        <h2>Inside the engineering lab</h2>
      </div>
      <p>Products, workflows, and publishing systems I’m actively refining. The current snapshot lives on the <a href="/now/">Now page</a>.</p>
    </div>
    <div class={styles.featureGrid}>
      {homeConfig.workbench.map((item) => (
        <article class={`${styles.featureCard} surface`}>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <a class={styles.featureLink} href={item.href}>
            Explore more
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class={styles.section}>
    <div class={styles.sectionHeader}>
      <div>
        <span class="eyebrow">Latest writing</span>
        <h2>Fresh notes from the notebook</h2>
      </div>
      <p>Recent writing, experiments, and practical implementation details.</p>
    </div>
    <ArticlePreview posts={posts.slice(0, 3)} wholeCardLink linkTagsToFilter={false} />
  </section>

  <section class={styles.section}>
    <div class={styles.sectionHeader}>
      <div>
        <span class="eyebrow">Featured topics</span>
        <h2>Start with the areas I keep returning to</h2>
      </div>
      <p>Use topic collections to jump into recurring themes without digging through the full archive.</p>
    </div>
    <div class={styles.featureGrid}>
      {featuredTopics.map((topic) => (
        <a class={`${styles.topicCard} surface`} href={`/topics/${topic.path}/`}>
          <div class={styles.topicLink}>
            <h3>{topic.name}</h3>
            <span>{topic.postCount} posts</span>
          </div>
          <p>{topic.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class={styles.section}>
    <div class={styles.sectionHeader}>
      <div>
        <span class="eyebrow">Currently exploring</span>
        <h2>Questions worth spending time on</h2>
      </div>
      <p>Areas I’m actively researching, prototyping, or pressure-testing in real projects.</p>
    </div>
    <div class={styles.featureGrid}>
      {homeConfig.exploring.map((item) => (
        <article class={`${styles.topicCard} surface`}>
          <h3>{item}</h3>
          <p>Notes and experiments will land in the blog as they turn into something useful.</p>
        </article>
      ))}
    </div>
  </section>

  <section class={styles.section}>
    <div class={styles.sectionHeader}>
      <div>
        <span class="eyebrow">Tools and stack</span>
        <h2>The stack I write from experience</h2>
      </div>
      <p>Static-first publishing, modern TypeScript, and lightweight infrastructure choices that keep the site maintainable.</p>
    </div>
    <div class={styles.stackGrid}>
      {homeConfig.stack.map((item) => (
        <div class={`${styles.stackItem} surface`}>{item}</div>
      ))}
    </div>
  </section>

  <Container>
    <section class={`${styles.ctaSection} surface`}>
      <div class={styles.sectionHeader}>
        <span class="eyebrow">Stay in touch</span>
        <h2>Building something useful?</h2>
      </div>
      <p>
        If you have a specific product, architecture, or delivery problem, send me the interesting part.
      </p>
      <a class={styles.primaryAction} href="/contact/">
        Send a message
      </a>
    </section>
  </Container>
</BaseLayout>
